<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechChain - Dashboard Overview</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Tong quan doanh so</h2>
        <a href="/dashboard/reports?filter=<%= filter %>&fromDate=<%= fromDate %>&toDate=<%= toDate %>" class="btn btn-outline-primary">Xem bao cao chi tiet</a>
      </div>

      <div class="card p-3 shadow-sm mb-3">
        <form class="row g-2 align-items-end" method="GET" action="/dashboard/overview">
          <input type="hidden" name="filter" value="all" />
          <input type="hidden" name="granularity" value="auto" />
          <div class="col-md-10">
            <label class="form-label mb-1 fw-semibold">Date range</label>
            <div id="overviewDateRangePicker" class="form-control d-flex justify-content-between align-items-center">
              <span></span>
              <span>▼</span>
            </div>
            <input type="hidden" name="dateRange" id="overviewDateRangeInput" value="<%= dateRangeText %>" />
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Ap dung</button>
          </div>
        </form>
        <div class="mt-2 small text-muted">
          Trang thai: <strong><%= isCustomRange ? "Dang loc theo khoang ngay" : "Dang hien thi mac dinh" %></strong>
        </div>
      </div>

      <% if (filterError) { %>
      <div class="alert alert-warning py-2"><%= filterError %></div>
      <% } %>

      <p class="text-muted">Pham vi du lieu: <strong><%= dateRangeLabel %></strong></p>

      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="card p-3 shadow-sm">
            <div class="small text-muted">Tong doanh thu</div>
            <div class="fw-bold fs-5">
              <%= Number(netProfit.totalRevenue || 0).toLocaleString("vi-VN") %> VND
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-3 shadow-sm">
            <div class="small text-muted">Tong gia von</div>
            <div class="fw-bold fs-5">
              <%= Number(netProfit.totalCost || 0).toLocaleString("vi-VN") %> VND
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-3 shadow-sm">
            <div class="small text-muted">Loi nhuan rong</div>
            <div class="fw-bold fs-5 text-success">
              <%= Number(netProfit.netProfit || 0).toLocaleString("vi-VN") %> VND
            </div>
          </div>
        </div>
      </div>

      <div class="card p-3 shadow-sm mb-4">
        <h5>Doanh thu theo thoi gian</h5>
        <% if (!monthlyRevenue || monthlyRevenue.length === 0) { %>
        <div class="text-muted py-4">Khong co du lieu doanh thu trong khoang thoi gian da chon.</div>
        <% } else { %>
        <canvas id="lineChart" height="300"></canvas>
        <% } %>
      </div>

      <div class="card p-3 shadow-sm">
        <h5>Doanh thu theo danh muc</h5>
        <% if (!revenueByCategory || revenueByCategory.length === 0) { %>
        <div class="text-muted py-4">Khong co du lieu doanh thu theo danh muc trong khoang thoi gian da chon.</div>
        <% } else { %>
        <canvas id="barChart" height="250"></canvas>
        <% } %>
      </div>
    </div>

    <script>
      const monthlyRevenue = <%- JSON.stringify(monthlyRevenue) %>;
      const categoryRevenue = <%- JSON.stringify(revenueByCategory) %>;
      const vndFormatter = new Intl.NumberFormat("vi-VN");
      const formatVnd = (value) => `${vndFormatter.format(Number(value || 0))} VND`;
      const formatTy = (value) => `${(Number(value) / 1000000000).toFixed(1)} ty`;
      const lineValues = monthlyRevenue.map((item) => Number(item.totalRevenue || 0));
      const barValues = categoryRevenue.map((item) => Number(item.totalRevenue || 0));

      function buildYAxisOptions(values, forceStartAtZero = false) {
        const safeValues = values.length ? values : [0];
        const minValue = Math.min(...safeValues);
        const maxValue = Math.max(...safeValues);
        const spread = Math.max(maxValue - minValue, Math.max(maxValue * 0.05, 1));
        const padding = spread * 0.05;
        const suggestedMin = forceStartAtZero ? 0 : Math.max(minValue - padding, 0);
        const suggestedMax = maxValue + padding;

        return {
          beginAtZero: forceStartAtZero,
          suggestedMin,
          suggestedMax,
          ticks: {
            maxTicksLimit: 10,
            callback: (value) => formatTy(value),
          },
        };
      }

      const lineCanvas = document.getElementById("lineChart");
      if (lineCanvas && monthlyRevenue.length > 0) {
        const lineCtx = lineCanvas.getContext("2d");
        new Chart(lineCtx, {
          type: "line",
          data: {
            labels: monthlyRevenue.map((item) => item.label),
            datasets: [
              {
                label: "Doanh thu (VND)",
                data: monthlyRevenue.map((item) => item.totalRevenue),
                borderColor: "#0d6efd",
                backgroundColor: "rgba(13,110,253,0.10)",
                fill: false,
                tension: 0,
                borderWidth: 5,
                pointRadius: 5,
                pointHoverRadius: 7,
                pointBorderWidth: 2,
                pointBackgroundColor: "#ffffff",
                pointBorderColor: "#0d6efd",
              },
            ],
          },
          options: {
            scales: {
              y: {
                ...buildYAxisOptions(lineValues, false),
                grid: {
                  color: "rgba(0,0,0,0.15)",
                  lineWidth: 1.2,
                },
              },
              x: {
                grid: {
                  color: "rgba(0,0,0,0.08)",
                },
              },
            },
            plugins: {
              datalabels: {
                color: "#0b5ed7",
                anchor: "end",
                align: "top",
                font: {
                  weight: "bold",
                  size: 10,
                },
                formatter: (value) => formatTy(value),
              },
              tooltip: {
                callbacks: {
                  label: (context) => ` ${formatVnd(context.raw)}`,
                },
              },
            },
          },
          plugins: [ChartDataLabels],
        });
      }

      const barCanvas = document.getElementById("barChart");
      if (barCanvas && categoryRevenue.length > 0) {
        const barCtx = barCanvas.getContext("2d");
        new Chart(barCtx, {
          type: "bar",
          data: {
            labels: categoryRevenue.map((item) => item.category),
            datasets: [
              {
                label: "Doanh thu theo danh muc (VND)",
                data: categoryRevenue.map((item) => item.totalRevenue),
                backgroundColor: "#20c997",
              },
            ],
          },
          options: {
            scales: {
              y: {
                ...buildYAxisOptions(barValues, true),
              },
            },
            plugins: {
              tooltip: {
                callbacks: {
                  label: (context) => ` ${formatVnd(context.raw)}`,
                },
              },
            },
          },
        });
      }

      $(function () {
        const rawRange = "<%= dateRangeText %>";
        const parts = rawRange ? rawRange.split(" to ") : [];
        let start = moment().subtract(29, "days");
        let end = moment();

        if (parts.length === 2 && moment(parts[0], "YYYY-MM-DD", true).isValid() && moment(parts[1], "YYYY-MM-DD", true).isValid()) {
          start = moment(parts[0], "YYYY-MM-DD");
          end = moment(parts[1], "YYYY-MM-DD");
        }

        function cb(startDate, endDate) {
          $("#overviewDateRangePicker span:first").html(
            startDate.format("MMMM D, YYYY") + " - " + endDate.format("MMMM D, YYYY")
          );
          $("#overviewDateRangeInput").val(
            startDate.format("YYYY-MM-DD") + " to " + endDate.format("YYYY-MM-DD")
          );
        }

        $("#overviewDateRangePicker").daterangepicker(
          {
            startDate: start,
            endDate: end,
            ranges: {
              Today: [moment(), moment()],
              Yesterday: [moment().subtract(1, "days"), moment().subtract(1, "days")],
              "Last 7 Days": [moment().subtract(6, "days"), moment()],
              "Last 30 Days": [moment().subtract(29, "days"), moment()],
              "This Month": [moment().startOf("month"), moment().endOf("month")],
              "Last Month": [
                moment().subtract(1, "month").startOf("month"),
                moment().subtract(1, "month").endOf("month"),
              ],
            },
          },
          cb
        );

        cb(start, end);
      });
    </script>
  </body>
</html>
