<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechChain - Dashboard Overview</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Tong quan doanh so</h2>
        <a href="/dashboard/reports?filter=<%= filter %>&fromDate=<%= fromDate %>&toDate=<%= toDate %>" class="btn btn-outline-primary">Xem bao cao chi tiet</a>
      </div>

      <div class="card p-3 shadow-sm mb-3">
        <form class="row g-2 align-items-end" method="GET" action="/dashboard/overview">
          <div class="col-md-3">
            <label class="form-label mb-1 fw-semibold">Loc nhanh</label>
            <select class="form-select" name="filter">
              <option value="all" <%= filter === "all" ? "selected" : "" %>>Tu 01/2025 den nay</option>
              <option value="thisMonth" <%= filter === "thisMonth" ? "selected" : "" %>>Thang nay</option>
              <option value="lastMonth" <%= filter === "lastMonth" ? "selected" : "" %>>Thang truoc</option>
              <option value="last7Days" <%= filter === "last7Days" ? "selected" : "" %>>7 ngay qua</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label mb-1 fw-semibold">Hien thi theo</label>
            <select class="form-select" name="granularity">
              <option value="day" <%= granularity === "day" ? "selected" : "" %>>Theo ngay</option>
              <option value="month" <%= granularity === "month" ? "selected" : "" %>>Theo thang</option>
              <option value="year" <%= granularity === "year" ? "selected" : "" %>>Theo nam</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label mb-1 fw-semibold">Date range</label>
            <input
              type="text"
              class="form-control"
              name="dateRange"
              id="overviewDateRange"
              placeholder="Chon khoang ngay"
              value="<%= dateRangeText %>"
            />
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Ap dung</button>
          </div>
        </form>
        <div class="mt-2 small text-muted">
          Trang thai: <strong><%= isCustomRange ? "Dang loc theo khoang ngay" : "Dang dung loc nhanh" %></strong>
          | Do thi: <strong><%= granularity === "day" ? "Theo ngay" : granularity === "year" ? "Theo nam" : "Theo thang" %></strong>
        </div>
      </div>

      <% if (filterError) { %>
      <div class="alert alert-warning py-2"><%= filterError %></div>
      <% } %>

      <p class="text-muted">Pham vi du lieu: <strong><%= dateRangeLabel %></strong></p>

      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="card p-3 shadow-sm">
            <div class="small text-muted">Tong doanh thu</div>
            <div class="fw-bold fs-5">
              <%= Number(netProfit.totalRevenue || 0).toLocaleString("vi-VN") %> VND
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-3 shadow-sm">
            <div class="small text-muted">Tong gia von</div>
            <div class="fw-bold fs-5">
              <%= Number(netProfit.totalCost || 0).toLocaleString("vi-VN") %> VND
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-3 shadow-sm">
            <div class="small text-muted">Loi nhuan rong</div>
            <div class="fw-bold fs-5 text-success">
              <%= Number(netProfit.netProfit || 0).toLocaleString("vi-VN") %> VND
            </div>
          </div>
        </div>
      </div>

      <div class="card p-3 shadow-sm mb-4">
        <h5>Doanh thu theo thoi gian</h5>
        <canvas id="lineChart" height="150"></canvas>
      </div>

      <div class="card p-3 shadow-sm">
        <h5>Doanh thu theo danh muc</h5>
        <canvas id="barChart" height="160"></canvas>
      </div>
    </div>

    <script>
      const monthlyRevenue = <%- JSON.stringify(monthlyRevenue) %>;
      const categoryRevenue = <%- JSON.stringify(revenueByCategory) %>;
      const vndFormatter = new Intl.NumberFormat("vi-VN");
      const formatVnd = (value) => `${vndFormatter.format(Number(value || 0))} VND`;
      const formatTy = (value) => `${Number(value) / 1000000000} ty`;

      const lineCtx = document.getElementById("lineChart").getContext("2d");
      new Chart(lineCtx, {
        type: "line",
        data: {
          labels: monthlyRevenue.map((item) => item.label),
          datasets: [
            {
              label: "Doanh thu (VND)",
              data: monthlyRevenue.map((item) => item.totalRevenue),
              borderColor: "#0d6efd",
              backgroundColor: "rgba(13,110,253,0.10)",
              fill: false,
              tension: 0,
              borderWidth: 4,
              pointRadius: 4,
              pointHoverRadius: 6,
              pointBorderWidth: 2,
              pointBackgroundColor: "#ffffff",
              pointBorderColor: "#0d6efd",
            },
          ],
        },
        options: {
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                maxTicksLimit: 10,
                callback: (value) => formatTy(value),
              },
              grid: {
                color: "rgba(0,0,0,0.15)",
                lineWidth: 1.2,
              },
            },
            x: {
              grid: {
                color: "rgba(0,0,0,0.08)",
              },
            },
          },
          plugins: {
            datalabels: {
              color: "#0b5ed7",
              anchor: "end",
              align: "top",
              font: {
                weight: "bold",
                size: 10,
              },
              formatter: (value) => formatTy(value),
            },
            tooltip: {
              callbacks: {
                label: (context) => ` ${formatVnd(context.raw)}`,
              },
            },
          },
        },
        plugins: [ChartDataLabels],
      });

      const barCtx = document.getElementById("barChart").getContext("2d");
      new Chart(barCtx, {
        type: "bar",
        data: {
          labels: categoryRevenue.map((item) => item.category),
          datasets: [
            {
              label: "Doanh thu theo danh muc (VND)",
              data: categoryRevenue.map((item) => item.totalRevenue),
              backgroundColor: "#20c997",
            },
          ],
        },
        options: {
          scales: {
            y: {
              beginAtZero: true,
              max: 80000000000,
              ticks: {
                stepSize: 10000000000,
                maxTicksLimit: 9,
                callback: (value) => formatTy(value),
              },
            },
          },
          plugins: {
            tooltip: {
              callbacks: {
                label: (context) => ` ${formatVnd(context.raw)}`,
              },
            },
          },
        },
      });

      flatpickr("#overviewDateRange", {
        mode: "range",
        dateFormat: "Y-m-d",
        conjunction: " to ",
      });
    </script>
  </body>
</html>
