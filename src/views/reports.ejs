<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechChain - Detail Reports</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Bao cao chi tiet</h2>
        <a href="/dashboard/overview?filter=<%= filter %>&fromDate=<%= fromDate %>&toDate=<%= toDate %>" class="btn btn-outline-primary">Quay lai tong quan</a>
      </div>

      <div class="card p-3 shadow-sm mb-3">
        <form class="row g-2 align-items-end" method="GET" action="/dashboard/reports">
          <div class="col-md-4">
            <label class="form-label mb-1 fw-semibold">Loc nhanh</label>
            <select class="form-select" name="filter">
              <option value="all" <%= filter === "all" ? "selected" : "" %>>Tu 01/2025 den nay</option>
              <option value="thisMonth" <%= filter === "thisMonth" ? "selected" : "" %>>Thang nay</option>
              <option value="lastMonth" <%= filter === "lastMonth" ? "selected" : "" %>>Thang truoc</option>
              <option value="last7Days" <%= filter === "last7Days" ? "selected" : "" %>>7 ngay qua</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label mb-1 fw-semibold">Date range</label>
            <input
              type="text"
              class="form-control"
              name="dateRange"
              id="reportsDateRange"
              placeholder="Chon khoang ngay"
              value="<%= dateRangeText %>"
            />
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Ap dung</button>
          </div>
        </form>
        <div class="mt-2 small text-muted">
          Trang thai: <strong><%= isCustomRange ? "Dang loc theo khoang ngay" : "Dang dung loc nhanh" %></strong>
        </div>
      </div>

      <% if (filterError) { %>
      <div class="alert alert-warning py-2"><%= filterError %></div>
      <% } %>

      <p class="text-muted">Pham vi du lieu: <strong><%= dateRangeLabel %></strong></p>

      <div class="card p-3 shadow-sm mb-4">
        <h5 class="mb-3">Top 10 khach hang</h5>
        <div class="table-responsive">
          <table class="table table-striped table-sm align-middle">
            <thead>
              <tr>
                <th>Ten</th>
                <th>Email</th>
                <th>So don</th>
                <th>Tong thanh toan</th>
              </tr>
            </thead>
            <tbody>
              <% topCustomers.forEach((row) => { %>
              <tr>
                <td><%= row.name %></td>
                <td><%= row.email %></td>
                <td><%= row.totalOrders %></td>
                <td><%= Number(row.totalSpent).toLocaleString("vi-VN") %> VND</td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card p-3 shadow-sm mb-4">
        <h5 class="mb-3">Hieu suat nhan vien</h5>
        <div class="table-responsive">
          <table class="table table-striped table-sm align-middle">
            <thead>
              <tr>
                <th>Ma NV</th>
                <th>Ten NV</th>
                <th>So don xu ly</th>
                <th>Doanh thu</th>
                <th>Thuong (1%)</th>
              </tr>
            </thead>
            <tbody>
              <% employeePerformance.forEach((row) => { %>
              <tr>
                <td><%= row.code %></td>
                <td><%= row.name %></td>
                <td><%= row.totalOrders %></td>
                <td><%= Number(row.totalRevenue).toLocaleString("vi-VN") %> VND</td>
                <td><%= Number(row.bonus).toLocaleString("vi-VN") %> VND</td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card p-3 shadow-sm">
        <h5 class="mb-3">Canh bao ton kho (stock &lt; 10)</h5>
        <div class="table-responsive">
          <table class="table table-striped table-sm align-middle">
            <thead>
              <tr>
                <th>San pham</th>
                <th>Danh muc</th>
                <th>Ton kho</th>
                <th>Gia ban</th>
              </tr>
            </thead>
            <tbody>
              <% lowStockProducts.forEach((row) => { %>
              <tr>
                <td><%= row.name %></td>
                <td><%= row.category %></td>
                <td class="text-danger fw-bold"><%= row.stock %></td>
                <td><%= Number(row.price).toLocaleString("vi-VN") %> VND</td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <script>
      flatpickr("#reportsDateRange", {
        mode: "range",
        dateFormat: "Y-m-d",
        conjunction: " to ",
      });
    </script>
  </body>
</html>
